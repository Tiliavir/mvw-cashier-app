{
  "name": "mvw-cashier-app",
  "version": "0.9.1",
  "description": "Browser-based cashier app for club events",
  "license": "MIT",
  "author": "Markus Lindenmann",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tiliavir/mvw-cashier-app.git"
  },
  "scripts": {
    "compile": "hugo --cleanDestinationDir --minify",
    "lint": "stylelint assets/scss/style.scss && eslint .",
    "validate": "npx vnu --skip-non-html --filterpattern '.*view-transition.*|.*CSS: Parse Error.*' public/**/*.html",
    "test": "npm run compile && node scripts/run-playwright.js",
    "build": "npm run compile && npm run lint && npm run validate && npm run test",
    "dev": "hugo serve --baseURL http://localhost:1313/"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.49.1",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@types/node": "^25.3.5",
    "eslint": "10.0.3",
    "globals": "17.4.0",
    "sass": "^1.97.3",
    "stylelint": "17.4.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.7.2",
    "vnu-jar": "26.3.10"
  }
}
